NODE_ENV=production
TZ=Asia/Shanghai
AUTOMATION_ENABLED=true
REVIEW_GATE_ENABLED=false
PAUSE_ON_SEVERE_ERROR=true
DAILY_SCHEDULE_INSTALLED=true
DAILY_COLLECTION_TIME=06:50
DAILY_DELIVERY_TIME=生成完成后
DAILY_MAX_ITEMS=15

ZARA_X_FEED_URL=https://raw.githubusercontent.com/zarazhangrui/follow-builders/main/feed-x.json
ZARA_PODCASTS_FEED_URL=https://raw.githubusercontent.com/zarazhangrui/follow-builders/main/feed-podcasts.json
ZARA_BLOGS_FEED_URL=https://raw.githubusercontent.com/zarazhangrui/follow-builders/main/feed-blogs.json
GITHUB_TOKEN=

LLM_BASE_URL=
LLM_MODEL=
MORNING_BRIEF_LLM_API_KEY=
MORNING_BRIEF_MASTER_KEY=

# Use the same credentials at Caddy and the API. Generate the Caddy hash with:
# caddy hash-password --plaintext 'replace-with-a-long-random-password'
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=
ADMIN_BASIC_AUTH_PASSWORD_HASH=
# Development escape hatch for Provider HTTP URLs. Private/loopback IPs remain blocked.
ALLOW_INSECURE_PROVIDER_HTTP=false

PUBLIC_URL=https://breakfast.151014.xyz
OPENCLAW_HOOK_URL=
OPENCLAW_HOOK_TOKEN=
OPENCLAW_CHANNEL=
OPENCLAW_TO=
