# Runtime
NODE_ENV=development
TZ=Asia/Shanghai
DATA_DIR=./data
DATABASE_URL=./data/morning-brief.sqlite

# Public/admin services
ADMIN_API_HOST=127.0.0.1
ADMIN_API_PORT=8787
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=
# Used by Caddy only; generate from ADMIN_BASIC_AUTH_PASSWORD with caddy hash-password.
ADMIN_BASIC_AUTH_PASSWORD_HASH=
ALLOW_INSECURE_PROVIDER_HTTP=false
VITE_ADMIN_API_URL=http://127.0.0.1:8787/api
PUBLIC_BRIEFS_DIR=../../data/briefs

# Upstream feeds
ZARA_X_FEED_URL=
ZARA_PODCASTS_FEED_URL=
ZARA_BLOGS_FEED_URL=
GITHUB_TOKEN=

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required before API Keys can be saved from the admin UI. Keep this stable.
MORNING_BRIEF_MASTER_KEY=

# Existing environment-backed providers remain supported for compatibility.
MORNING_BRIEF_LLM_API_KEY=

# Optional OpenAI-compatible defaults for initial local setup.
LLM_BASE_URL=
LLM_MODEL=
