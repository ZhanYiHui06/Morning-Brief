# Runtime
NODE_ENV=development
TZ=Asia/Shanghai
DATA_DIR=./data
DATABASE_URL=./data/morning-brief.sqlite

# Public/admin services
ADMIN_API_HOST=127.0.0.1
ADMIN_API_PORT=8787
VITE_ADMIN_API_URL=http://127.0.0.1:8787/api
PUBLIC_BRIEFS_DIR=../../data/briefs

# Upstream feeds
ZARA_X_FEED_URL=
ZARA_PODCASTS_FEED_URL=
ZARA_BLOGS_FEED_URL=
GITHUB_TOKEN=

# LLM secrets are referenced by name from the database.
# Never persist their plaintext values in SQLite or browser storage.
MORNING_BRIEF_LLM_API_KEY=

# Optional OpenAI-compatible defaults for initial local setup.
LLM_BASE_URL=
LLM_MODEL=
