---
import type { DailyBrief, LinkItem } from "@/lib/briefs";

interface Props { brief: DailyBrief; }
const { brief } = Astro.props;
const statusText = brief.status === "complete" ? "内容完整" : brief.status === "partial" ? "部分来源缺失" : "降级摘要";
const itemMeta = (item: LinkItem) => [item.author || item.source, item.category].filter(Boolean).join(" · ");
---

<article class="brief">
  <header class="brief-hero">
    <div class="issue" data-enter>
      <span>DAILY / {brief.date.slice(0, 4)}</span>
      <strong>{brief.date.slice(5).replace("-", ".")}</strong>
    </div>
    <div class="hero-copy">
      <div class="hero-meta" data-enter>
        <span class="section-label">DAILY BRIEF</span>
        <span class:list={["status", brief.status]}>{statusText}</span>
      </div>
      <h1 class="display" data-enter>{brief.title}</h1>
      <p data-enter>{brief.deck || "从 Builders 的讨论与开发者社区的行动中，辨认今天真正值得关注的变化。"}</p>
    </div>
  </header>

  {brief.warnings.length > 0 && (
    <aside class="warning" aria-label="数据提示" data-reveal>
      <b>数据说明</b>
      <span>{brief.warnings.join("；")}</span>
    </aside>
  )}

  <section class="brief-section highlights" data-reveal>
    <header class="section-heading">
      <div><span class="section-label">TOP SIGNALS</span><h2 class="display">今日关键信息</h2></div>
      <span class="section-count">{String(brief.highlights.length).padStart(2, "0")} / 03</span>
    </header>
    {brief.highlights.length ? (
      <div class="highlight-list">
        {brief.highlights.map((item, index) => (
          <article class="highlight">
            <span class="ordinal">{String(index + 1).padStart(2, "0")}</span>
            <span class="highlight-body">
              <small>{itemMeta(item)}</small>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              {item.reason && <em>{item.reason}</em>}
            </span>
          </article>
        ))}
      </div>
    ) : <p class="inline-empty">今天没有达到入选标准的重点事件。</p>}
  </section>

  <section class="brief-section builders" data-reveal>
    <header class="section-heading">
      <div><span class="section-label">BUILDER DESK</span><h2 class="display">Builders 在说什么</h2></div>
      <p>完整保留入选原文；按主题组织，不替代作者表达。</p>
    </header>
    {brief.builderTopics.length ? (
      <div class="topic-list">
        {brief.builderTopics.map((topic, index) => (
          <section class="topic">
            <div class="topic-title"><span>{String(index + 1).padStart(2, "0")}</span><h3>{topic.title}</h3>{topic.summary && <p>{topic.summary}</p>}</div>
            <div class="topic-items">
              {topic.items.map((item) => (
                <article class="builder-entry">
                  <small>{itemMeta(item)}</small>
                  <strong>{item.title}</strong>
                  {item.summary && <p class="event-summary">{item.summary}</p>}
                  {item.originalSources?.length ? (
                    <div class="original-list">
                      {item.originalSources.map((source) => (
                        <section class="original-source">
                          <header><span>{source.author || source.source}</span>{source.author && <small>{source.source}</small>}</header>
                          <div class="source-text"><small>原文</small><p>{source.content}</p></div>
                          {source.translatedContent && (
                            <div class="translation"><small>中文翻译</small><p>{source.translatedContent}</p></div>
                          )}
                          {source.url && <a href={source.url} target="_blank" rel="noreferrer">查看来源 ↗</a>}
                        </section>
                      ))}
                    </div>
                  ) : (
                    <div class="original-source legacy-source">
                      <p>{item.summary}</p>
                      {item.url && <a href={item.url} target="_blank" rel="noreferrer">查看来源 ↗</a>}
                    </div>
                  )}
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    ) : <p class="inline-empty">Builders 频道今天保持安静。</p>}
  </section>

  <section class="brief-section github" data-reveal>
    <header class="section-heading">
      <div><span class="section-label">OPEN SOURCE PULSE</span><h2 class="display">GitHub 今日趋势</h2></div>
      <p>沿用 GitHub Daily Trending 官方顺序，模型只负责解释。</p>
    </header>
    {brief.githubTrending.length ? (
      <div class="repo-list">
        {brief.githubTrending.map((repo) => (
          <a class="repo" href={repo.url} target="_blank" rel="noreferrer">
            <span class="repo-rank">#{String(repo.rank).padStart(2, "0")}</span>
            <span class="repo-main">
              <small>{repo.language || "多语言"}{repo.starsToday != null && ` · +${repo.starsToday.toLocaleString()} today`}</small>
              <strong>{repo.fullName}</strong>
              <p>{repo.summary}</p>
            </span>
            <span class="repo-stars">{repo.totalStars?.toLocaleString() ?? "未知"}<small>STARS</small></span>
          </a>
        ))}
      </div>
    ) : <p class="inline-empty">今天尚未获得 GitHub Trending 数据。</p>}
  </section>

  {brief.suggestedActions.length > 0 && (
    <section class="action-section" data-reveal>
      <div><span class="section-label">NEXT MOVE</span><h2 class="display">下一步行动</h2><p>最多两项，依据今日关键信息生成。</p></div>
      <ol>{brief.suggestedActions.slice(0, 2).map((action) => <li>{action}</li>)}</ol>
    </section>
  )}

  <div class="brief-nav" data-reveal>
    <a class="brief-nav-link" href="/archive/">
      <span><small>KEEP THE CONTEXT</small><strong>翻阅往期晨报</strong></span>
      <b>进入归档 →</b>
    </a>
    <a class="brief-nav-link" href={`/brief/${brief.date}/sources/`}>
      <span><small>SOURCE LEDGER · {String(brief.rawItems.length).padStart(2, "0")}</small><strong>查看今日所有原文</strong></span>
      <b>查看原文 →</b>
    </a>
  </div>
</article>

<style>
  .brief-hero { display: grid; grid-template-columns: 160px minmax(0, 1fr); gap: 58px; padding: 28px 0 82px; }
  .issue { display: flex; min-height: 210px; flex-direction: column; border-top: 5px solid var(--signal); padding-top: 13px; }
  .issue span, .issue small { color: var(--ink-2); font-size: 10px; letter-spacing: .12em; }
  .issue strong { margin-top: 16px; font: 670 30px/1 var(--font); letter-spacing: -.05em; }
  .issue small { margin-top: auto; }
  .hero-meta { display: flex; justify-content: space-between; gap: 20px; align-items: center; }
  .hero-copy h1 { max-width: 820px; margin: 32px 0 22px; font-size: clamp(42px, 5.8vw, 76px); line-height: 1.02; }
  .hero-copy > p { max-width: 720px; margin: 0; color: var(--ink-2); font-size: 18px; line-height: 1.8; }
  .warning { margin: -28px 0 54px 218px; padding: 15px 18px; border-top: 1px solid var(--warning); border-bottom: 1px solid var(--line); color: var(--ink-2); font-size: 13px; }
  .warning b { margin-right: 18px; color: var(--warning); }
  .brief-section { padding: 66px 0; border-top: 1px solid var(--line); }
  .section-heading { display: flex; align-items: end; justify-content: space-between; gap: 34px; margin-bottom: 34px; }
  .section-heading h2, .action-section h2 { margin: 8px 0 0; font-size: clamp(30px, 4vw, 48px); line-height: 1.08; }
  .section-heading > p { max-width: 340px; margin: 0; color: var(--ink-2); font-size: 12px; line-height: 1.6; }
  .section-count { color: var(--ink-2); font: 550 11px/1 var(--mono); }
  .highlight-list { border-top: 2px solid var(--ink); }
  .highlight { display: grid; grid-template-columns: 76px minmax(0, 1fr); gap: 24px; padding: 30px 10px 32px 0; border-bottom: 1px solid var(--line); }
  .highlight:last-child { border-bottom: 0; }
  .ordinal, .repo-rank { color: var(--signal); font: 650 13px/1 var(--mono); }
  .highlight-body small, .topic-items small, .repo-main small { color: var(--ink-2); font-size: 10px; letter-spacing: .09em; text-transform: uppercase; }
  .highlight h3 { max-width: 820px; margin: 7px 0 9px; font-size: 23px; line-height: 1.28; letter-spacing: -.03em; }
  .highlight p, .topic-items p, .repo p { margin: 0; color: var(--ink-2); font-size: 14px; line-height: 1.72; }
  .highlight em { display: block; margin-top: 13px; color: var(--ink); font-size: 12px; font-style: normal; }
  .topic-list { border-top: 2px solid var(--ink); }
  .topic { display: grid; grid-template-columns: minmax(190px, .8fr) minmax(0, 1.8fr); gap: 50px; padding: 29px 0 34px; border-top: 1px solid var(--line); }
  .topic:first-child { border-top: 0; }
  .topic-title > span { color: var(--signal); font: 650 11px/1 var(--mono); }
  .topic-title h3 { margin: 14px 0 8px; font-size: 21px; line-height: 1.3; }
  .topic-title p { margin: 0; color: var(--ink-2); font-size: 13px; }
  .builder-entry { padding: 0 0 30px; }
  .builder-entry + .builder-entry { padding-top: 30px; border-top: 1px solid var(--line); }
  .topic-items strong { display: block; margin: 6px 0 7px; font-size: 16px; }
  .event-summary { margin-bottom: 18px !important; padding-left: 12px; border-left: 2px solid var(--line-strong); font-size: 12px !important; }
  .original-list { display: grid; gap: 12px; }
  .original-source { padding: 17px 18px 18px; border: 1px solid var(--line); background: var(--surface); }
  .original-source header { display: flex; align-items: baseline; gap: 8px; margin-bottom: 10px; }
  .original-source header span { font-size: 12px; font-weight: 680; }
  .original-source header small { color: var(--ink-2); font-size: 9px; }
  .source-text > small, .translation > small { display: block; margin-bottom: 7px; color: var(--ink-2); font-size: 9px; font-weight: 650; letter-spacing: .08em; }
  .original-source p { margin: 0; color: var(--ink); font-size: 14px; line-height: 1.85; white-space: pre-wrap; overflow-wrap: anywhere; }
  .translation { margin-top: 18px; padding-top: 18px; border-top: 1px solid var(--line-strong); }
  .translation p { color: var(--ink-2); }
  .original-source a { display: inline-block; margin-top: 13px; color: var(--signal); font-size: 11px; font-weight: 650; text-decoration: underline; text-underline-offset: 3px; }
  .legacy-source { margin-top: 15px; }
  .repo-list { border-top: 2px solid var(--ink); }
  .repo { display: grid; grid-template-columns: 74px minmax(0, 1fr) 86px; gap: 26px; align-items: start; padding: 24px 9px 26px 0; border-bottom: 1px solid var(--line); transition: background-color 160ms ease, padding 160ms ease; }
  .repo:hover { padding-left: 14px; background: var(--surface); }
  .repo-main strong { display: block; margin: 6px 0 7px; font-size: 18px; letter-spacing: -.02em; }
  .repo-stars { text-align: right; font: 650 13px/1.2 var(--mono); }
  .repo-stars small { display: block; margin-top: 5px; color: var(--ink-2); font-size: 8px; letter-spacing: .11em; }
  .action-section { display: grid; grid-template-columns: .8fr 1.2fr; gap: 58px; margin-top: 62px; padding: 42px; background: var(--ink); color: var(--paper); }
  .action-section .section-label { color: var(--signal); }
  .action-section p { color: color-mix(in srgb, var(--paper) 66%, transparent); font-size: 12px; }
  .action-section ol { margin: 0; padding: 0; list-style: none; counter-reset: actions; }
  .action-section li { counter-increment: actions; position: relative; padding: 0 0 20px 46px; font-size: 15px; line-height: 1.65; border-bottom: 1px solid color-mix(in srgb, var(--paper) 18%, transparent); }
  .action-section li + li { padding-top: 20px; }
  .action-section li::before { content: "0" counter(actions); position: absolute; left: 0; color: var(--signal); font: 650 11px/1.6 var(--mono); }
  .action-section li + li::before { top: 20px; }
  .brief-nav { display: grid; grid-template-columns: 1fr 1fr; margin-top: 18px; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--paper); }
  .brief-nav-link { min-width: 0; min-height: 112px; display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 28px 24px 28px 0; background: var(--paper); transition: background-color 160ms ease, padding 160ms ease; }
  .brief-nav-link + .brief-nav-link { padding-left: 24px; border-left: 1px solid var(--line); }
  .brief-nav-link:hover { padding-left: 12px; background: var(--surface); }
  .brief-nav-link + .brief-nav-link:hover { padding-left: 36px; }
  .brief-nav-link small { display: block; color: var(--ink-2); font-size: 9px; letter-spacing: .13em; }
  .brief-nav-link strong { display: block; margin-top: 6px; font-size: 18px; }
  .brief-nav-link b { flex: 0 0 auto; color: var(--signal); font-size: 12px; }
  .inline-empty { margin: 0; padding: 30px 0; border-top: 2px solid var(--ink); border-bottom: 1px solid var(--line); color: var(--ink-2); }

  @media (max-width: 760px) {
    .brief-hero { grid-template-columns: 1fr; gap: 30px; padding: 10px 0 56px; }
    .issue { min-height: auto; display: grid; grid-template-columns: 1fr auto; border-top-width: 3px; }
    .issue strong { margin-top: 7px; }
    .issue small { grid-column: 2; grid-row: 1 / 3; align-self: end; }
    .hero-meta { align-items: flex-start; flex-direction: column; }
    .hero-copy h1 { margin-top: 24px; font-size: clamp(38px, 10.8vw, 54px); }
    .hero-copy > p { font-size: 16px; }
    .warning { margin: -18px 0 42px; }
    .brief-section { padding: 48px 0; }
    .section-heading { align-items: flex-start; flex-direction: column; gap: 14px; }
    .highlight { grid-template-columns: 42px 1fr; gap: 12px; padding-right: 0; }
    .highlight h3 { font-size: 19px; }
    .topic { grid-template-columns: 1fr; gap: 24px; }
    .original-source { padding: 15px; }
    .repo { grid-template-columns: 44px 1fr; gap: 10px; }
    .repo-stars { display: none; }
    .action-section { grid-template-columns: 1fr; gap: 28px; padding: 30px 24px; }
    .brief-nav { grid-template-columns: 1fr; }
    .brief-nav-link { min-height: 94px; padding: 23px 0; }
    .brief-nav-link + .brief-nav-link { padding: 23px 0; border-top: 1px solid var(--line); border-left: 0; }
    .brief-nav-link:hover, .brief-nav-link + .brief-nav-link:hover { padding-left: 10px; }
  }
</style>
